# MANTRIQ Configuration

# Backend options: ollama, openai, gemini, local, mock
MANTRIQ_BACKEND=local

# Model name (optional, defaults to backend-specific defaults)
# MANTRIQ_MODEL=llama2

# API Keys (only required if using cloud backends)
# OPENAI_API_KEY=your_openai_api_key_here
# GOOGLE_API_KEY=your_google_api_key_here
